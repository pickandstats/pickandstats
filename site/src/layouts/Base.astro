---
import { Font } from 'astro:assets';
import ConsentBanner from '../components/ConsentBanner.astro';
const {
  title,
  description = 'Estadísticas y guías de las ligas menores del baloncesto español.',
  tipo = 'website',
  ogTitulo,
} = Astro.props;

// URL absoluta de esta página y de la imagen para compartir
const urlCanonica = new URL(Astro.url.pathname, Astro.site);
const urlImagen = new URL('/og.png', Astro.site);
// Para compartir sobra el sufijo de marca que sí queremos en la pestaña
const tituloSocial = ogTitulo ?? title.replace(/\s·\sPick&Stats$/, '');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-180.png" />
    <Font cssVariable="--fuente-titulo" preload />
    <Font cssVariable="--fuente-texto" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={urlCanonica} />

    <!-- Open Graph: miniatura al compartir el enlace -->
    <meta property="og:type" content={tipo} />
    <meta property="og:site_name" content="Pick&Stats" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:title" content={tituloSocial} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={urlCanonica} />
    <meta property="og:image" content={urlImagen} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Google Analytics 4 con Consent Mode v2: denegado por defecto -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied'
      });
    </script>
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-ZR4J29Z3NS"></script>
    <script is:inline>
      gtag('js', new Date());
      gtag('config', 'G-ZR4J29Z3NS', { anonymize_ip: true });
    </script>
  </head>
  <body>
    <header class="cinta">
      <div class="cinta-fila">
        <a href="/" class="cinta-marca">Pick<span>&amp;</span>Stats</a>
        <nav class="cinta-nav">
          <a href="/">Inicio</a>
          <a href="/guias">Guías</a>
          <a href="/app/">Estadísticas</a>
        </nav>
      </div>
    </header>

    <main class="contenedor">
      <slot />
    </main>

    <footer class="pie">
      <div class="contenedor">
        <p class="pie-marca">Pick&amp;Stats · Estadísticas de ligas menores del baloncesto español</p>
        <p class="pie-enlaces"><a href="/legal">Aviso legal y privacidad</a></p>
      </div>
    </footer>

    <ConsentBanner />

    <style>
      :root {
        --tinta: #16233a;
        --tinta-suave: #5a6478;
        --fondo: #f6f7f9;
        --panel: #ffffff;
        --linea: #e3e6eb;
        --acento: #e8622c;
        --positivo: #0a7d33;
        --negativo: #c0392b;
        --radio: 8px;
        --alto-cinta: 59px;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        background: var(--fondo);
        color: var(--tinta);
        font-family: var(--fuente-texto), system-ui, sans-serif;
        font-size: 16px;
        line-height: 1.6;
      }

      .contenedor { max-width: 860px; margin: 0 auto; padding: 0 20px; }

      .cinta { background: var(--panel); border-bottom: 1px solid var(--linea); }

      /* Fija solo en escritorio, igual que en la app (web/src/index.css) */
      @media (min-width: 768px) {
        .cinta { position: sticky; top: 0; z-index: 100; }
        html { scroll-padding-top: calc(var(--alto-cinta) + 8px); }
      }
      .cinta-fila {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 20px; max-width: 1100px; margin: 0 auto;
      }
      .cinta-marca {
        font-family: var(--fuente-titulo);
        font-weight: 700; font-size: 30px; letter-spacing: .5px;
        text-transform: uppercase; text-decoration: none; color: var(--tinta);
      }
      .cinta-marca span { color: var(--acento); }

      .cinta-nav a {
        font-family: var(--fuente-titulo);
        font-size: 17px; font-weight: 600; text-transform: uppercase;
        letter-spacing: .3px; margin-left: 20px;
        text-decoration: none; color: var(--tinta-suave);
      }
      .cinta-nav a:hover { color: var(--acento); }

      main.contenedor { padding-top: 32px; padding-bottom: 48px; }

      h1 {
        font-family: var(--fuente-titulo);
        font-weight: 700; font-size: 40px; letter-spacing: .5px;
        text-transform: uppercase; line-height: 1.1; margin: 0 0 16px;
      }
      h2, h3 {
        font-family: var(--fuente-titulo);
        font-weight: 600; letter-spacing: .3px; color: var(--tinta);
        margin-top: 32px;
      }
      h2 { font-size: 28px; }
      h3 { font-size: 22px; }

      a { color: var(--acento); }

      .pie {
        border-top: 1px solid var(--linea);
        padding: 20px; margin-top: 40px;
        color: var(--tinta-suave); font-size: 13px; text-align: center;
      }
      .pie p { margin: 0; }
      .pie-enlaces { margin-top: 6px; }
      .pie-enlaces a { color: var(--tinta-suave); text-decoration: none; }
      .pie-enlaces a:hover { color: var(--acento); text-decoration: underline; }
    </style>
  </body>
</html>
